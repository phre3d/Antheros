//------------------------------------------------------------
// convert [aloud] blocks to Obsidian callouts
//
// note: requires Obsidian CSS snippet to define the
//    callout [!read-aloud]
//------------------------------------------------------------
function Aloud2Markdown(block) {
    block = block.replace("[aloud]", "> [!read-aloud] **Read Aloud** \r\n \r\n");
    block = block.replaceAll("\r\n", "\r\n > ");
    block = block.replace("[/aloud]", "\r\n");
    return block;
}

//------------------------------------------------------------
// convert World Anvil links markdown links
//------------------------------------------------------------1
function Link2Markdown(link) {
    // get the link text, type and target
    const regex = /@\[([^\]]*)\]\(([^\):]*):([^\)]*)\)/gi;
    match = regex.exec(link);

    // construct new link using type as a subdirectory
    const newLink = "[[" + match[2] + "/" + match[1] + "|" + match[1] + "]]";

    return newLink;
}

//-----------------------------------------------
// convert bbcode table to markdown
//-----------------------------------------------
function Table2Markdown(bbcode) {
	
    // get rid of \r & \n 
    bbcode = bbcode.replaceAll("\r\n", "\n");
    bbcode = bbcode.replaceAll("\n\r", "\n");
    bbcode = bbcode.replaceAll("\n\n", "\n");
    bbcode = bbcode.replaceAll("\n"," ")

	// remove column sizes from [th] tags
	bbcode = bbcode.replace(/\[th:\d+\]/g, '[th]')
	
    // Remove [table] and [/table] tags (they are not needed in markdown)
    bbcode = bbcode.replace(/\[table\](.*?)\[\/table\]/gis, '$1');

    // Convert [tr] to a new row in markdown table (line breaks)
    bbcode = bbcode.replaceAll("[tr]", " ")
    bbcode = bbcode.replaceAll("[/tr]", " \|\n")

    // Convert [td] to normal table cell (with a pipe symbol '|')
    bbcode = bbcode.replace(/\[td\](.*?)\[\/td\]/gis, '| $1 ');

    // Convert [th] to table header ('|')
    bbcode = bbcode.replace(/\[th\](.*?)\[\/th\]/gis, '| $1 ');

    // remove whitespace at the start of new line (i.e. after \n)
    bbcode = bbcode.replace(/\n\s+/g, '\n')
    // and the start/end of the string
    bbcode = bbcode.trimStart().trimEnd()

    // Add the table header separator row for markdown (---)
    let rows = bbcode.split('\n');
    if (rows.length > 1) {
        rows.splice(1, 0, '|---|'.repeat(rows[0].split('|').length - 2)); // Adding separator row
    }
    bbcode = rows.join('|\n');

    // remove double pipes
    bbcode = bbcode.replaceAll("||", "|")

	// ensure a line before and after the Table
	bbcode = '\n' + bbcode + '\n'

    return bbcode;
}

//----------------------------------------------
// convert [roll:XdY] tags to text
//----------------------------------------------
function Roll2Markdown(text) {
console.log("Roll2Md::: " + text)

	let result
	// remove whitespace
	text = text.replace(/\s+/g, '')
	// now parse it
    const regex = /\[roll:(\d*)d(\d+)(?:\+(\d+))?\]/i;
    let match = text.match(regex);


console.log("Roll2Md:::::::m1=" + match[1])
console.log("Roll2Md:::::::m2=" + match[2]) 
console.log("Roll2Md:::::::m3=" + match[3])


    if (match) {
        result = match[1] + "d" + match[2]
		if (match[3] !== undefined) {
			result = result + match[3];
		}
    } else {
        result = "roll xDy";
    }
	return result
}

//-------------------------------------------
// convert bbcode lists to markdown
//-------------------------------------------
function List2Markdown(input) {
    const tokens = tokenize(input);
    let index = 0;

    function parseList(indent = 0) {
        let md = "";
        let listType = "ul";
        let counter = 1;

        // open tag
        if (tokens[index]?.type === "list_open") {
            listType = tokens[index].listType;
            index++;
        }

        while (index < tokens.length) {
            const token = tokens[index];

            if (token.type === "list_close") {
                index++;
                break;
            }

            if (token.type === "item_open") {
                index++;
                let content = "";

                while (
                    index < tokens.length &&
                    !["item_open", "list_close"].includes(tokens[index].type)) {
                    if (tokens[index].type === "list_open") {
                        content += "\n" + parseList(indent + 1);
                    } else {
                        content += tokens[index].value || "";
                        index++;
                    }
                }

                const prefix =
                    listType === "ol"
                     ? `${counter++}. `
                     : `- `;

                md +=
                " ".repeat(indent) +
                prefix +
                content.trim().replace(/\n+$/, "") +
                "\n";
            } else {
                index++;
            }
        }

        return md;
    }

    function tokenize(str) {
        const regex = /\[\/?(ul|ol)\]|\[\*\]|\[li\]|\[\/li\]/gi;
        const result = [];
        let lastIndex = 0;
        let match;

        while ((match = regex.exec(str)) !== null) {
            if (match.index > lastIndex) {
                result.push({
                    type: "text",
                    value: str.slice(lastIndex, match.index)
                });
            }

            const tag = match[0].toLowerCase();

            if (tag === "[ul]" || tag === "[ol]") {
                result.push({
                    type: "list_open",
                    listType: tag === "[ol]" ? "ol" : "ul"
                });
            } else if (tag === "[/ul]" || tag === "[/ol]") {
                result.push({
                    type: "list_close"
                });
            } else if (tag === "[*]" || tag === "[li]") {
                result.push({
                    type: "item_open"
                });
            } else if (tag === "[/li]") {
                // ignored (graceful handling)
            }

            lastIndex = regex.lastIndex;
        }

        if (lastIndex < str.length) {
            result.push({
                type: "text",
                value: str.slice(lastIndex)
            });
        }

        return result;
    }

    let output = "";
    while (index < tokens.length) {
        if (tokens[index].type === "list_open") {
            output += parseList(0);
        } else {
            output += tokens[index].value || "";
            index++;
        }
    }

    return output.trim();
}

//===============================================
//
// main function to convert bbcode to markdown
//
//===============================================
function hb_bb2md(text) {

    const DEBUG = false;
    const DEBUG2 = false;

    if (DEBUG2 == true) {
        console.log('\n========================================\nBB2MD::::\n' + text)
    };

    // if text is null, undefined or empty, return an empty string
    if (text == null) {
        if (DEBUG == true) {
            console.log('BB2MD::::Skipping null/undefined text')
        }
        return ''
    }
    if (text == '') {
        if (DEBUG == true) {
            console.log('BB2MD::::Skipping empty text')
        }
        return ''
    }

    const conversions = [
        // basic tags that have obsidian/markdown equivalents
        ['[b]', ' **'],           ['[/b]', '** '],
        ['[i]', ' *'],            ['[/i]', '* '],
        ['[u]', '<u>'],           ['[/u]', '</u>'],
        ['[mark]', ' =='],        ['[/mark]', '== '],
        ['[s]', ' ~~'],           ['[/s]', '~~ '],
        ['[sup]', '<sup>'],       ['[/sup]', '</sup>'],
        ['[sub]', '<sub>'],       ['[/sub]', '</sub>'],
        ['[center]', '<center>'], ['[/center]', '</center>'],
        ['[small]', '<small>'],   ['[/small]', '</small>'],
        ['[br]', '<br>'],
        ['[hr]', '\n---\n'],

        // tags where obsidian/markdown doesn't have an end-tag
        ['[p]', '\n\n'], ['[/p]', ' '],
        ['[h1]', '# '], ['[/h1]', ' '],
        ['[h2]', '## '], ['[/h2]', ' '],
        ['[h3]', '### '], ['[/h3]', ' '],
        ['[h4]', '#### '], ['[/h4]', ' '],
        ['[h5]', '##### '], ['[/h5]', ' '],
        ['[h6]', '###### '], ['[/h6]', ' '],

        // tags we're going to just remove for now
        //   note: container/subcontainer need special processing
        ['[row]', ''],    ['[/row]', ''],
        ['[col]', ''],    ['[/col]', ''],
        ['[col3]', ''],   ['[/col3]', ''],
		['[spoiler]', ''], ['[/spoiler]', ''],

        // Unicode characters
        ['\0022', '"'], ['\0026', '&'], ['\0027', "'"],
        ['\003c', '<'], ['\003e', '>'], ['\2014', '-'],
        ['\2018', "'"], ['\2019', "'"], ['\2026', '…'],

        // HTML  (for Foundry exports)
        ['<p>', '\n\n'], ['</p>', ' '],
        ['<br>', '\n'],  ['<br/>', '\n'], ['<br />', '\n'],
        ['&gt;', '>'],   ['&lt;', '<'],
        ['\u0022', '"'], ['\u0026', '&'], ['\u0027', "'"],
        ['\u003c', '<'], ['\u003e', '>'], ['\u2014', '-'],
        ['\u2018', "'"], ['\u2019', "'"], ['\u2026', '…']
	]

        //
        // remove anchors in bbcode headings
        //  e.g. [h2|anchorName]
        //
        text = text.replaceAll(/\[h2\|[^\]]+\]/gi, "[h2]");
        if (DEBUG) {
            console.log('BB2MD::::   After anchors >>' + text + '<<')
        }

        // ensure headings are at the start of a line
        text = text.replace(/(?<!\n)\[h[1-6]\]/g, '\n$&');
        // ensure headings are followed by a new line
        text = text.replace(/\[\/h[1-6]\](?!\s*\n)/g, (match) => match + '\n');
        if (DEBUG) {
            console.log('BB2MD::::   After Headings >>' + text + '<<')
        }

        // remove \r
        text = text.replace("\\r", "");

        //
        // remove [container] and [subcontainer] tags
        //
        text = text.replace(/\[container:[^\]]*\]/gi, "");
        text = text.replaceAll("[/container]", "");
        text = text.replace(/\[subcontainer:[^\]]*\]/gi, "");
        text = text.replaceAll("[/subcontainer]", "");
        if (DEBUG) {
            console.log('BB2MD::::   After [container] >>' + text + '<<')
        }

        //
        // do simple replacements
        //
        for (let i = 0; i < conversions.length; i++) {
            const [search, replace] = conversions[i];
            text = text.replaceAll(search, replace);
        }
        if (DEBUG) {
            console.log('BB2MD::::   After tags >>' + text + '<<')
        }

        //
        // replace [roll:xdy]
        //
        //text = text.replace(/\[roll:(\d*)d(\d+)(?:\+(\d+))?\]/gi, (match) => {
        //    return Roll2Markdown(match);
        //});
		text = text.replace(/\[roll:[^\]]*\]/g, '')
        if (DEBUG) {
            console.log('BB2MD::::   After [roll] >>' + text + '<<')
        }

        //
        // convert WA block references to obsidian embeds
        //
        text = text.replace(/\[block:(\d+)\]/g, '![[$1]]');
        text = text.replace(/\[blocklink:(\d+)\]/g, '![[$1]]');

        //
        // Replace [url] links with [text](url)
        //
        text = text.replace(/\[url:([^\]]+)\]\s*([\s\S]+?)\s*\[\/url\]/gi, '[$2]($1)');
        if (DEBUG) {
            console.log('BB2MD::::   After [url] links >>' + text + '<<')
        }

        //
        // Replace [img] with ![alt text](url)
        //
        let oldTag = (text.match(/\[img:[^\]]+\]/i) || [])[0];
        //console.log("-----------------------\n[img]tag is " + oldTag + '\nwhich is of type: ' + typeof oldTag)
        while (oldTag != null) {
            let newTag = img2img(oldTag);
            text = text.replace(oldTag, newTag);
            oldTag = (text.match(/\[img:[^\]]+\]/i) || [])[0];
            //console.log("-----------------------\n[img]tag is " + oldTag + '\nwhich is of type: ' + typeof oldTag)
        }
        if (DEBUG) {
            console.log('BB2MD::::   After [img] >>' + text + '<<')
        }

        //
        // Replace [quote]...[/quote] with > ... (quote block)
        //
        text = text.replace(/\[quote\](.*?)\[\/quote\]/gs, '> $1');
        if (DEBUG) {
            console.log('BB2MD::::   After [quote] >>' + text + '<<')
        }

        //
        // Replace [code]...[/code] with inline code `...`
        //
        text = text.replace(/\[code\](.*?)\[\/code\]/gis, '`$1`');
        if (DEBUG) {
            console.log('BB2MD::::   After [code] >>' + text + '<<')
        }

        //
        // convert [aloud]
        //
        text = text.replace(/\[aloud\](.*?)\[\/aloud\]/gis, (match) => {
            return Aloud2Markdown(match);
        });
        if (DEBUG) {
            console.log('BB2MD::::   After [aloud] >>' + text + '<<')
        }

        //
        // convert WA links
        //
        text = text.replace(/@\[([^\]]*)\]\(([^\):]*):([^\)]*)\)/gi, (match) => {
            return Link2Markdown(match);
        });
        if (DEBUG) {
            console.log('BB2MD::::   After WA links >>' + text + '<<')
        }

        //
        // convert lists
        //
        text = List2Markdown(text);
        if (DEBUG) {
            console.log('BB2MD::::   After [ol], [ul] >>' + text + '<<')
        }

        //
        // convert [table]
        //
        text = text.replace(/\[table\](.*?)\[\/table\]/gis, (match) => {
            return Table2Markdown(match);
        });
        if (DEBUG) {
            console.log('BB2MD::::   After [table] >>' + text + '<<')
        }

		// flip <center>**text**</center> to be **<center>text</center>**
		text = text.replace(/<center>\s*\*\*([\s\S]*?)\*\*\s*<\/center>/g, '**<center>$1</center>**')

        // return the converted string
        return text;
}
 
 
//=====================================================================================
//=====================================================================================
//  handlebar helper to process an array, returning a list of names
//=====================================================================================
//=====================================================================================
function hb_array2list(items, type) {

    let titles;
    const joiner = ']]\n- [[' + type + '/'

        titles = '- [[' + type + '/' + items.map(item => item.title).join(joiner) + ']]'

        return titles;

}


//=====================================================================================
//=====================================================================================
//  take a YAML string and find the value of a given tag
//=====================================================================================
//=====================================================================================
function hb_yamlvalue(yamlString, tag) {

    function yamlToJson(yamlString) {
        const lines = yamlString.split("\n");
        const result = {};
        const stack = [{
                obj: result,
                indent: -1
            }
        ];

        for (let line of lines) {
            if (!line.trim() || line.trim().startsWith("#"))
                continue;

            const indent = line.search(/\S/);
            const [key, ...rest] = line.trim().split(":");
            const value = rest.join(":").trim();

            while (stack.length > 1 && stack[stack.length - 1].indent >= indent) {
                stack.pop();
            }

            const parent = stack[stack.length - 1].obj;

            if (value === "" || value === null) {
                parent[key.trim()] = {};
                stack.push({
                    obj: parent[key.trim()],
                    indent
                });
            } else {
                parent[key.trim()] = isNaN(value)
                     ? value === "true" ? true : value === "false" ? false : value
                     : Number(value);
            }
        }

        return result;
    }

    //
    // mainline
    //
    let result;

    //console.log('Looking for: ' + tag);

    // cconvert yampl to json
    const json = yamlToJson(yamlString);

    // if the field exists and is defined get the value
    if (json[tag] != null) {
        const yValue = tag.split(".").reduce((obj, key) => obj?.[key], json);
        result = yValue;
        // trim start/end quote marks if present
        if (yValue[0] == "'" || yValue[0] == '"') {
            // remove quotes around the result
            result = yValue.slice(1, -1);
        }

        // ensure headings are at the start of a line
        result = result.replace(/(?<!\n)\[h[1-6]\]/g, '\n$&');
        // ensure headings are followed by a new line
        result = result.replace(/\[\/h[1-6]\](?!\s*\n)/g, (match) => match + '\n');

        // more clean up
        result = result.replace(/\\r\\n/g, ' ');
    } else {
        result = null;
    }

    //console.log('     Found: ' + result);

    return result;

}

//=====================================================================================
//=====================================================================================
//  Determine attribute modifier from score
//=====================================================================================
//=====================================================================================
function hb_getMod(score) {

    const scoreMod = [
        ['1', '-5'], ['2', '-4'], ['3', '-4'], ['4', '-3'], ['5', '-3'], ['6', '-2'], ['7', '-2'], ['8', '-1'], ['9', '-1'], ['10', '+0'],
        ['11', '+0'], ['12', '+1'], ['13', '+1'], ['14', '+2'], ['15', '+2'], ['16', '+3'], ['17', '+3'], ['18', '+4'], ['19', '+4'], ['20', '+5'],
        ['21', '+5'], ['22', '+6'], ['23', '+6'], ['24', '+7'], ['25', '+7'], ['26', '+8'], ['27', '+8'], ['28', '+9'], ['29', '+9'], ['30', '+10']
    ];

    for (const x of scoreMod) {
        if (score == x[0]) {
            return x[1];
        }
    }
    return 'n/a';
}

//=====================================================================================
//=====================================================================================
//  take a World Anvil 'slug' and extract the article type
//=====================================================================================
//=====================================================================================
function hb_slug2type(slug) {

    // grab everything after the last "-"
    let type = slug.slice(slug.lastIndexOf('-') + 1);

    // upper case the 1st character
    type = type.charAt(0).toUpperCase() + type.slice(1);

    return type;

}

//=====================================================================================
//=====================================================================================
//  take a World Anvil tags and convert to Obsidian tags
//=====================================================================================
//=====================================================================================
function hb_tags2tags(tags) {

	if (tags == null) {
	    return ""
    } 
	if (tags == "") {
        return ""
    }

    const obsTags = "#" + tags.replaceAll(" ", "_").replaceAll(",", " #");

    return obsTags;

}

//=====================================================================================
//=====================================================================================
//  return the value of a given field.   solves issues where directly accessing it
//  in the template causes an issue.  e.g. {{length}}
//=====================================================================================
//=====================================================================================
function hb_json2value(field) {
    return field;
}


//=====================================================================================
//=====================================================================================
//  in some places WA uses a form a a Markdown table that needs tweaking
//=====================================================================================
//=====================================================================================
function hb_mdtable(text) {

    let table = text

    // fix piping and newlines
    table = table.replaceAll("\\r", "");
    table = table.replaceAll("\\n", "|\n|");
    table = "|" + table + "|";

    // Add the table header separator row for markdown (---)
    let rows = table.split('\n');
    if (rows.length > 1) {
        rows.splice(1, 0, '|---|'.repeat(rows[0].split('|').length - 2)); // Adding separator row
    }
    table = rows.join('|\n|');
    table = table.replaceAll("||", "|")

    // remove attempts at bolding the heading
    table= table.replaceAll("[b]", "")
    table= table.replaceAll("[\/b]", "")

    return table;

}

//=====================================================================================
//=====================================================================================
//  generate random character string for use as a (probably) unique id
//=====================================================================================
//=====================================================================================
function hb_uuid(howLong) {

	let x
	// make sure the parm is an integer
	if(howLong != null && /^\d+$/.test(howLong)) {
		x = +howLong
	} else {
		return "Invalid length"
	}

	const id = Array.from({length: x}, () => 
		'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789'
		.charAt(Math.floor(Math.random() * 62))).join('');
	return id
}


//=====================================================================================
//=====================================================================================
//  translate History significance to text
//=====================================================================================
//=====================================================================================
function hb_sig2text(significance) {
//console.log('Significance: ' + significance);
	switch(significance) {
		case 0:
			return 'Milestone';
		case 1:
			return 'Major';
		case 2:
			return 'Important';
		case 3:
			return 'Minor';
		case 4:
			return 'Trivial';
		case 5:
			return 'Insignificant';
	default:
		return ' '
	} 

}


//
// register the functions as handlebars helpers
//
handlebars.registerHelper('bb2md', hb_bb2md);
handlebars.registerHelper('array2list', hb_array2list);
handlebars.registerHelper('yamlvalue', hb_yamlvalue);
handlebars.registerHelper('getMod', hb_getMod);
handlebars.registerHelper('slug2type', hb_slug2type);
handlebars.registerHelper('tags2tags', hb_tags2tags);
handlebars.registerHelper('json2value', hb_json2value);
handlebars.registerHelper('mdtable', hb_mdtable);
handlebars.registerHelper('uuid', hb_uuid);
handlebars.registerHelper('sig2text', hb_sig2text);

